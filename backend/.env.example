# NewGen Backend – Environment Variables
# Copy this file to .env and adjust values for your environment.
# .env is git-ignored; .env.example is committed.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Standard libpq / pgx connection string.
# Change credentials to match your docker-compose.yml overrides.
DATABASE_URL=postgres://newgen:newgen_secret@localhost:5432/newgen?sslmode=disable

POSTGRES_USER=newgen
POSTGRES_PASSWORD=newgen_secret
POSTGRES_DB=newgen
POSTGRES_PORT=5432

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-super-secret-key-min-32-chars
JWT_TTL_HOURS=24

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── API Keys (external callers / agents) ────────────────────────────────────
API_KEY_ARCELIK=test-api-key-arcelik-001
API_KEY_BEKO=test-api-key-beko-002

# ─── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@newgen.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
